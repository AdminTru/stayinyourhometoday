---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';

// Read ?name= from URL for personalized greeting
const nameParam = Astro.url.searchParams.get('name') ?? '';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Stay In Your Home Today",
  "description": "CDPS-certified foreclosure help and short sale assistance for Utah homeowners",
  "url": "https://stayinyourhometoday.com",
  "telephone": "(435) 244-3210",
  "email": "brad@truhomebuyer.com",
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "UT",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "State", "name": "Utah" },
    { "@type": "AdministrativeArea", "name": "Salt Lake County" },
    { "@type": "AdministrativeArea", "name": "Tooele County" },
    { "@type": "AdministrativeArea", "name": "Weber County" }
  ],
  "knowsAbout": ["Foreclosure Prevention", "Short Sale", "Loan Modification", "Distressed Property"],
  "hasCredential": "CDPS — Certified Distressed Property Specialist"
};
---

<BaseLayout
  title="Stay In Your Home Today | Free Foreclosure Help for Utah Homeowners"
  description="Facing foreclosure in Utah? CDPS-certified broker Tiffany Lancaster at Stay In Your Home Today offers free, confidential options reviews. Call (435) 244-3210."
  schema={localBusinessSchema}
>

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container" style="position:relative;z-index:1;">
      <h1>
        Hi{nameParam ? ` ${nameParam}` : ''}, We Know You're
        <span class="highlight">Worried About Your Home</span>
      </h1>
      <p class="hero-sub">
        We're reaching out because you still have time to explore your options —
        and we're here to help you understand what those options are.
      </p>

      <!-- Countdown timers -->
      <div class="timer-row">
        <a href="/contactus" class="timer-widget" aria-label="Days since Notice of Default — click to get help">
          <div class="timer-label">Since Notice of Default</div>
          <div class="timer-display" id="timer-nod">—</div>
          <div class="timer-sublabel">days elapsed</div>
        </a>
        <a href="/contactus" class="timer-widget" aria-label="Days until Foreclosure Auction — click to get help">
          <div class="timer-label">Until Foreclosure Auction</div>
          <div class="timer-display" id="timer-auction">—</div>
          <div class="timer-sublabel">days remaining (est.)</div>
        </a>
      </div>

      <div class="btn-group" style="justify-content:center; margin-bottom:2.5rem;">
        <a href="tel:+14352443210" class="btn btn--primary btn--lg">
          📞 Call Us Now — (435) 244-3210
        </a>
        <a href="/contactus" class="btn btn--outline-white btn--lg">
          Get Your Free Options Review
        </a>
      </div>

      <!-- YouTube embed -->
      <div class="video-container">
        <div class="video-wrap">
          <iframe
            src="https://www.youtube.com/embed/xkcCTKTykYs?autoplay=1&mute=1&rel=0&modestbranding=1&playsinline=1"
            title="Stay In Your Home Today — How We Help Utah Homeowners Facing Foreclosure"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== YOU DON'T HAVE TO GO THROUGH THIS ALONE ===================== -->
  <section class="section">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <h2>You Don't Have To Go Through This Alone</h2>
        <p style="font-size:1.05rem; color:var(--color-gray-500); margin-bottom:1.5rem;">
          A Notice of Default is frightening — but it is not the end. Thousands of Utah homeowners
          have faced this exact situation and found a path forward. Stay In Your Home Today and
          Tiffany Lancaster, CDPS-certified broker, exist for one reason: to make sure you know
          every option before time runs out.
        </p>
        <ul class="check-list" style="margin-bottom:2rem;">
          <li>We work with homeowners — not banks or investors</li>
          <li>100% free consultation, no strings attached</li>
          <li>Certified Distressed Property Specialist (CDPS) on your side</li>
          <li>We've helped families keep their homes, sell on their terms, and avoid deficiency judgments</li>
          <li>We know Utah's foreclosure timeline inside and out — and we'll explain it all in plain English</li>
          <li>Confidential — your situation stays between us</li>
        </ul>
        <div class="btn-group">
          <a href="/contactus" class="btn btn--primary">Talk to Tiffany — It's Free</a>
          <a href="tel:+14352443210" class="btn btn--secondary">(435) 244-3210</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== UTAH FORECLOSURE PROCESS ===================== -->
  <section class="section section--alt" id="foreclosure-process">
    <div class="container">
      <div style="max-width:820px; margin:0 auto;">
        <div class="eyebrow">Utah Foreclosure Process</div>
        <h2>Understanding Utah's Foreclosure Timeline</h2>
        <p style="color:var(--color-gray-500); margin-bottom:2.5rem; font-size:1.05rem;">
          Utah is a non-judicial foreclosure state, which means lenders can foreclose without going
          to court. The entire process — from your first missed payment to the trustee's sale — can
          happen in as little as 240 days. Here's how it works:
        </p>

        <!-- Phase 1 -->
        <div class="timeline-stage" id="phase-1">
          <div class="stage-badge">Phase 1</div>
          <h3>Notice of Default (NOD)</h3>
          <div class="stage-duration">Typically begins 90+ days after first missed payment</div>
          <p>
            Once your lender records a Notice of Default, the clock officially starts. This is a
            public record — which is why you may be receiving mailers. From the NOD date, you
            have <strong>90 days</strong> before the lender can schedule the trustee's sale.
            This phase is your widest window for options including reinstatement, loan modification,
            and sale alternatives.
          </p>
          <div class="callout-warning">
            <strong>⚠ Action Window</strong>
            Most loan modification and short sale options must be initiated during this phase.
            Don't wait for a Notice of Trustee Sale.
          </div>
        </div>

        <!-- Phase 2 -->
        <div class="timeline-stage" id="phase-2">
          <div class="stage-badge">Phase 2</div>
          <h3>Notice of Trustee's Sale</h3>
          <div class="stage-duration">Recorded after the 90-day NOD period</div>
          <p>
            The Notice of Trustee's Sale sets the auction date — at least <strong>21 days</strong>
            after it's recorded. At this stage, your options narrow significantly. Reinstatement
            is still possible up to 5 days before the sale, but most modification programs require
            earlier application. A short sale or deed-in-lieu negotiation must be in active
            progress before this deadline.
          </p>
          <div class="callout-warning">
            <strong>⚠ Narrowing Window</strong>
            Lenders are not required to postpone the sale while reviewing a modification or short sale
            unless you have a formal application on file. Act immediately.
          </div>
        </div>

        <!-- Phase 3 -->
        <div class="timeline-stage timeline-stage--warning" id="phase-3">
          <div class="stage-badge stage-badge--warning">Phase 3</div>
          <h3>Trustee's Sale (Foreclosure Auction)</h3>
          <div class="stage-duration">Minimum 21 days after Notice of Trustee's Sale</div>
          <p>
            The property is sold at public auction, typically on the courthouse steps or online.
            If no one outbids the lender's opening bid, the lender takes title. You lose all
            equity. After the sale, you have <strong>no right of redemption</strong> in Utah —
            the sale is final. Eviction proceedings can begin immediately.
          </p>
          <div class="callout-warning">
            <strong>🚨 Final Stage</strong>
            Once the gavel falls, your options are gone. The minimum total timeline from NOD to sale
            is 111 days — but most sales occur at the 240-day mark. Don't assume you have more time.
          </div>
        </div>

        <div style="text-align:center; margin-top:2.5rem;">
          <a href="/foreclosure-timeline" class="btn btn--primary" style="margin-right:1rem;">
            Full Foreclosure Timeline Guide
          </a>
          <a href="/contactus" class="btn btn--secondary">Get a Free Options Review</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== OPTIONS COMPARISON ===================== -->
  <section class="section section--dark" id="options">
    <div class="container">
      <div class="eyebrow" style="color:var(--color-teal); text-align:center;">Your Choices</div>
      <h2 class="text-center" style="color:var(--color-white); margin-bottom:0.75rem;">
        Your Options Side-By-Side
      </h2>
      <p class="text-center" style="color:rgba(255,255,255,0.72); max-width:640px; margin:0 auto 2.5rem;">
        Every situation is different. Here's an honest look at the options available to Utah
        homeowners after a Notice of Default — with their real deadlines.
      </p>

      <div class="options-grid">

        <div class="option-card">
          <h3>Loan Modification</h3>
          <span class="deadline-tag">Must apply before Trustee's Sale</span>
          <p>
            Your lender restructures your loan — lower rate, extended term, or deferred payments.
            Best option if you want to stay in the home and have verifiable income. Takes 30–90 days
            to process. Must be in progress before the NTS is filed for best results.
          </p>
        </div>

        <div class="option-card option-card--featured">
          <h3>Short Sale</h3>
          <span class="deadline-tag">Active application required before NTS</span>
          <p>
            Sell the home for less than the mortgage balance with lender approval. Avoids foreclosure
            on your credit report, may eliminate deficiency. Tiffany Lancaster can negotiate directly
            with your lender on your behalf — at no cost to you.
          </p>
        </div>

        <div class="option-card">
          <h3>Traditional Sale</h3>
          <span class="deadline-tag deadline-tag--ok">Available while equity exists</span>
          <p>
            If you have equity, selling traditionally gives you the most control and typically the
            best net proceeds. Must close before the trustee's sale date. Works best in Phase 1
            or early Phase 2.
          </p>
        </div>

        <div class="option-card option-card--featured">
          <h3>Cash Offer</h3>
          <span class="deadline-tag deadline-tag--ok">Can close in 7–21 days</span>
          <p>
            Sell to a cash buyer quickly, close before the auction, and walk away with whatever
            equity remains. No repairs, no showings, no contingencies. Often the fastest way to
            stop the clock and preserve credit.
          </p>
        </div>

        <div class="option-card">
          <h3>Deed in Lieu</h3>
          <span class="deadline-tag">Lender approval required — start early</span>
          <p>
            Voluntarily transfer the deed to your lender in exchange for release of the mortgage
            obligation. Less damaging to credit than a completed foreclosure. Requires lender
            cooperation — not all lenders accept. Best negotiated in Phase 1.
          </p>
        </div>

        <div class="option-card">
          <h3>Bankruptcy</h3>
          <span class="deadline-tag">Temporary protection only</span>
          <p>
            Filing Chapter 13 triggers an automatic stay that halts the foreclosure — temporarily.
            Can buy time to cure arrears through a repayment plan. Does not eliminate the debt.
            Requires an attorney. Should be evaluated alongside other options, not as a first resort.
          </p>
        </div>

      </div>

      <div style="text-align:center; margin-top:3rem;">
        <p style="color:rgba(255,255,255,0.72); max-width:560px; margin:0 auto 1.5rem;">
          Not sure which option fits your situation? Stay In Your Home Today offers a free,
          no-obligation options review — we'll help you map out every path.
        </p>
        <div class="btn-group" style="justify-content:center;">
          <a href="/contactus" class="btn btn--primary btn--lg">Get My Free Options Review</a>
          <a href="tel:+14352443210" class="btn btn--outline-white btn--lg">(435) 244-3210</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <CTABlock
    heading="Time is the one thing you can't get back."
    subtext="Every day that passes without a plan is a day closer to the auction. Tiffany Lancaster and the Stay In Your Home Today team are ready to help — free, confidential, no obligation."
    primaryLabel="Schedule My Free Review"
  />

</BaseLayout>

<!-- Timer script — runs client-side, content degrades gracefully without JS -->
<script>
  // Timers are display-only decoration — content is fully readable without them
  function setTimer(id: string, days: number) {
    const el = document.getElementById(id);
    if (el) el.textContent = days.toString();
  }

  // Read ?nod=YYYY-MM-DD from URL if present, otherwise use a reasonable placeholder
  const params = new URLSearchParams(window.location.search);
  const nodStr = params.get('nod');

  if (nodStr) {
    const nodDate = new Date(nodStr);
    const today = new Date();
    const msPerDay = 86400000;
    const elapsed = Math.max(0, Math.floor((today.getTime() - nodDate.getTime()) / msPerDay));
    const utahMinDays = 240;
    const remaining = Math.max(0, utahMinDays - elapsed);
    setTimer('timer-nod', elapsed);
    setTimer('timer-auction', remaining);
  } else {
    // Default display values when no NOD date is provided
    setTimer('timer-nod', 0);
    setTimer('timer-auction', 240);
  }
</script>
